{
  "name": "movie-reviews-api",
  "version": "1.0.0",
  "description": "Vercel-ready Express API for a Movie Reviews app",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "check": "for file in $(find src -name '*.js' -print); do node --check \"$file\"; done"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",

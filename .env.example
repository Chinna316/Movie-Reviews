# Local development only. Do not commit real secrets.
NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=

# JWT secret for your users/reviews API (use 32+ random characters)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend.vercel.app

# TMDB v4 read access token
TMDB_READ_ACCESS_TOKEN=

# Optional alternative: TMDB v3 API key
TMDB_API_KEY=
